rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read their own user document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // No write access
    }

    // Users can only read their own orders
    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }

    // Users can only read their own proxy orders
    match /proxyOrders/{proxyOrderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }

    // Users can only read their own VoIP orders
    match /voipOrders/{voipOrderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }

    // Users can only read their own VCC orders
    match /vccOrders/{vccOrderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }

    // Users can only read their own VCC transactions
    match /vccTransactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }

    // Users can only read their own recharges
    match /recharges/{rechargeId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }

    // Users can only read their own tickets
    match /tickets/{ticketId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // No write access
    }


    // Users can read allCatalog/catalog document for service selection (read-only)
    match /allCatalog/catalog {
      allow read: if request.auth != null;
      allow write: if false; // No write access
    }

    // Users can read stnUSA collection and its subcollections for number search (read-only)
    match /stnUSA/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can read stnUK collection and its subcollections for number search (read-only)
    match /stnUK/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can read stnIndia collection and its subcollections for number search (read-only)
    match /stnIndia/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can read stnGermany collection and its subcollections for number search (read-only)
    match /stnGermany/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can read stnFrance collection and its subcollections for number search (read-only)
    match /stnFrance/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can read middleUSA collection and its subcollections for number search (read-only)
    match /middleUSA/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can read longUSA collection and its subcollections for number search (read-only)
    match /longUSA/{optionId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access

      // Allow read access to services subcollection
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if false; // No write access
      }
    }

    // Users can ONLY read the emptySimcardCatalog document from fees collection
    match /fees/emptySimcardCatalog {
      allow read: if request.auth != null;
      allow write: if false; // No write access
    }

    // Users can ONLY read the emptySimcardCatalogUK document from fees collection
    match /fees/emptySimcardCatalogUK {
      allow read: if request.auth != null;
      allow write: if false; // No write access
    }

    // Users can ONLY read the emptySimcard document from fees collection
    match /fees/emptySimcard {
      allow read: if request.auth != null;
      allow write: if false; // No write access
    }

    // Users can ONLY read the proxyCatalog document from fees collection
    match /fees/proxyCatalog {
      allow read: if request.auth != null;
      allow write: if false; // No write access
    }

    // Users can read sendSMS/opt1/countries subcollection for SMS pricing (read-only)
    match /sendSMS/opt1/countries/{countryId} {
      allow read: if request.auth != null;
      allow write: if false; // No write access
    }

    // Default deny all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}